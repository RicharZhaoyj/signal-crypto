<script>
function toNum(val) {
  if (val == null) return 0;
  if (typeof val === 'number') return val;
  return parseFloat(String(val).replace('%','')) || 0;
}

async function loadData() {
  const updateEl = document.getElementById('updateTime');
  
  try {
    const res = await fetch('/data.json?t=' + Date.now());
    if (!res.ok) throw new Error('HTTP ' + res.status);
    
    const d = await res.json();
    
    let timeStr = '刚刚更新';
    if (d.timestamp) {
      try {
        timeStr = new Date(d.timestamp).toLocaleString('zh-CN', { 
          timeZone: 'Asia/Shanghai',
          month: '2-digit', day: '2-digit',
          hour: '2-digit', minute: '2-digit'
        });
      } catch(e) {}
    }
    updateEl.innerHTML = `⏰ ${timeStr}`;

    safeRender(() => renderTopCoins(d));
    safeRender(() => renderOverview(d));
    safeRender(() => renderVolatileTable(d));
    safeRender(() => renderSidewaysTable(d));
    safeRender(() => renderVolumeTable(d));

  } catch (e) {
    console.error('数据加载失败:', e);
    updateEl.innerHTML = '⏰ 数据加载失败';
    const msg = '<div class="error">数据正在更新中，请稍后刷新</div>';
    document.getElementById('topCoins').innerHTML = msg;
    document.getElementById('volatileTable').innerHTML = `<tr><td colspan="5" class="error">更新中...</td></tr>`;
    document.getElementById('sidewaysTable').innerHTML = `<tr><td colspan="6" class="error">更新中...</td></tr>`;
    document.getElementById('volumeTable').innerHTML = `<tr><td colspan="5" class="error">更新中...</td></tr>`;
  }
}

function safeRender(fn) {
  try { fn(); } catch(e) { console.error(e); }
}

function renderTopCoins(d) {
  const container = document.getElementById('topCoins');
  let html = '';
  
  let btcData = d.btc;
  let ethData = d.eth;
  
  if (!btcData && d.short_term) {
    btcData = d.short_term.find(x => x.pair === 'BTC-USDT');
    ethData = d.short_term.find(x => x.pair === 'ETH-USDT');
  }
  
  if (btcData) {
    const change = toNum(btcData.change24h || btcData.change);
    html += createCoinCard('₿ BTC', btcData.price || btcData.last, change);
  }
  if (ethData) {
    const change = toNum(ethData.change24h || ethData.change);
    html += createCoinCard('⟠ ETH', ethData.price || ethData.last, change);
  }
  
  container.innerHTML = html || '<div class="loading">暂无数据</div>';
}

function createCoinCard(name, price, change) {
  const c = change || 0;
  const changeColor = c >= 0 ? '#ff4d4f' : '#52c41a';
  const sign = c >= 0 ? '+' : '';
  const priceStr = typeof price === 'number' ? price.toLocaleString() : (price || '0');
  return `
    <div class="coin-card">
      <div class="coin-name">${name}</div>
      <div class="coin-price">$${priceStr}</div>
      <div class="coin-change" style="color:${changeColor}">${sign}${c.toFixed(2)}%</div>
      <a class="trade-btn" href="https://www.kxmqpwrlvjt.com/join/72697785" target="_blank" rel="nofollow noopener">去OKX交易 →</a>
    </div>
  `;
}

function renderOverview(d) {
  const el = document.getElementById('overview');
  const total = d.totalPairs || 300;
  const up = d.upCount || 180;
  const down = d.downCount || 100;
  const vol = d.totalVolume || 18000000000;
  
  const sentiment = d.sentiment === 'bullish' ? '🟢 乐观' : 
                    d.sentiment === 'bearish' ? '🔴 悲观' : '🟡 中性';
  
  el.innerHTML = `
    <div class="ov-item"><div class="ov-label">监控品种</div><div class="ov-value">${total}</div></div>
    <div class="ov-item"><div class="ov-label">上涨</div><div class="ov-value" style="color:#52c41a">${up}</div></div>
    <div class="ov-item"><div class="ov-label">下跌</div><div class="ov-value" style="color:#ff4d4f">${down}</div></div>
    <div class="ov-item"><div class="ov-label">24h总成交</div><div class="ov-value">$${(vol/1e9).toFixed(1)}B</div></div>
    <div class="ov-item"><div class="ov-label">市场情绪</div><div class="ov-value" style="font-size:1em">${sentiment}</div></div>
  `;
}

function renderVolatileTable(d) {
  const tbody = document.getElementById('volatileTable');
  let list = d.volatile || [];
  
  if (list.length === 0 && d.short_term) {
    list = d.short_term.filter(x => Math.abs(toNum(x.change)) >= 5).slice(0, 15);
  }
  
  if (list.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#666;">暂无异动数据</td></tr>';
    return;
  }
  
  let html = '';
  list.slice(0, 15).forEach((item, i) => {
    const change = toNum(item.change24h || item.change);
    const color = change >= 0 ? '#ff4d4f' : '#52c41a';
    const sign = change >= 0 ? '+' : '';
    const price = item.price || item.last || 0;
    const vol = item.volume || 0;
    const volStr = vol > 1e8 ? `$${(vol/1e8).toFixed(2)}B` : `$${(vol/1e6).toFixed(2)}M`;
    
    html += `<tr>
      <td>${i+1}</td>
      <td class="sym">${item.symbol || item.pair}</td>
      <td>$${typeof price === 'number' ? price.toFixed(4) : price}</td>
      <td style="color:${color};font-weight:bold">${sign}${change.toFixed(2)}%</td>
      <td>${volStr}</td>
    </tr>`;
  });
  tbody.innerHTML = html;
}

function renderSidewaysTable(d) {
  const tbody = document.getElementById('sidewaysTable');
  let list = d.sideways || [];
  
  if (list.length === 0 && d.long_term_sideways) list = d.long_term_sideways;
  if (list.length === 0 && d.flat_start) list = d.flat_start;
  
  if (list.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#666;">暂无横盘蓄势数据</td></tr>';
    return;
  }
  
  let html = '';
  list.slice(0, 12).forEach((item, i) => {
    const change = toNum(item.change24h || item.change);
    const color = change >= 0 ? '#ff4d4f' : '#52c41a';
    const sign = change >= 0 ? '+' : '';
    const price = item.price || item.last || 0;
    const volStr = (item.volume || 0) > 1e8 ? `$${(item.volume/1e8).toFixed(2)}B` : `$${(item.volume/1e6).toFixed(2)}M`;
    
    const vola7d = item.vola_7d || '--';
    const pos7d = item.position_7d || '--';
    
    html += `<tr>
      <td>${i+1}</td>
      <td class="sym">${item.symbol || item.pair}</td>
      <td>$${typeof price === 'number' ? price.toFixed(4) : price}</td>
      <td>${vola7d}%</td>
      <td>${pos7d}%</td>
      <td style="color:${color};font-weight:bold">${sign}${change.toFixed(2)}%</td>
    </tr>`;
  });
  tbody.innerHTML = html;
}

function renderVolumeTable(d) {
  const tbody = document.getElementById('volumeTable');
  let list = d.topVolume || d.short_term || [];
  
  if (list.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#666;">暂无数据</td></tr>';
    return;
  }
  
  let html = '';
  list.slice(0, 10).forEach((item, i) => {
    const change = toNum(item.change24h || item.change);
    const color = change >= 0 ? '#ff4d4f' : '#52c41a';
    const sign = change >= 0 ? '+' : '';
    const price = item.price || item.last || 0;
    const vol = item.volume || 0;
    const volStr = vol > 1e8 ? `$${(vol/1e8).toFixed(2)}B` : `$${(vol/1e6).toFixed(2)}M`;
    
    html += `<tr>
      <td>${i+1}</td>
      <td class="sym">${item.symbol || item.pair}</td>
      <td>$${typeof price === 'number' ? price.toFixed(4) : price}</td>
      <td style="color:${color}">${sign}${change.toFixed(2)}%</td>
      <td>${volStr}</td>
    </tr>`;
  });
  tbody.innerHTML = html;
}

function subscribe() {
  const email = document.getElementById('emailInput').value;
  const msg = document.getElementById('subMsg');
  if (!email) return;

  fetch('/api/subscribe', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({email})
  })
  .then(r => r.json())
  .then(data => {
    msg.style.display = 'block';
    msg.style.color = data.success ? '#52c41a' : '#ff4d4f';
    msg.textContent = data.success ? '✅ 订阅成功！明天早8点起将收到日报' : '❌ ' + (data.error || '提交失败');
    if (data.success) document.getElementById('emailInput').value = '';
  })
  .catch(() => {
    msg.style.display = 'block';
    msg.style.color = '#ff4d4f';
    msg.textContent = '❌ 提交失败，请重试';
  });
}

loadData();
</script>
</body>
</html>